# --- Secrets: NEVER commit the YNAB token or anything that could hold it ---
.env
.env.*
!.env.example
*.token
*.secret
config.json
.config/

# --- Local bank exports (may contain real financial data) ---
# Sample/test fixtures may be committed deliberately; force-add them with
#   git add -f references/sample.csv
*.csv

# --- Populated review forms & resolved data (contain real transaction data) ---
# Ignore every generated HTML in web/ EXCEPT the committed, data-free template.
web/*.html
!web/review.template.html
*.out.html
ynab-review*.html
resolved*.json
prepared*.json

# --- Python ---
__pycache__/
*.pyc
